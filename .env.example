# ─── EVM (BSC mainnet) ────────────────────────────────────────────────────
# Private key OR mnemonic of the BSC OApp delegate (0x… that is set as
# delegate on the BSC Endpoint for this OApp). Will sign setSendConfig /
# setReceiveConfig / setEnforcedOptions on BSC.
PRIVATE_KEY=
RPC_URL_BSC=https://bsc-dataseed.bnbchain.org

# ─── Solana mainnet ───────────────────────────────────────────────────────
# Path to the keypair JSON of the Solana OApp delegate.
# This MUST be the keypair for CZ7DsdcWaCvLLQUHyWRPoB8QvN2PhoW74fi7oxJTh6Jg.
SOLANA_KEYPAIR_PATH=./keys/delegate.json
# Optional: dedicated RPC (mainnet rate-limits hurt during wiring)
RPC_URL_SOLANA=https://api.mainnet-beta.solana.com
